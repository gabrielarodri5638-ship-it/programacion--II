import math
class estadistica:
    def __init__(self,lista):
        self.__datos=lista

    def promedio(self):
        n=len(self.__datos)
        sum=0
        for i in range (n):
            sum=sum+self.__datos[i]
        return sum/n
    def desviacion(self):
        prom=self.promedio()
        n=len(self.__datos)
        num=0
        for i in range (n):
            num=num+(self.__datos[i]-prom)**2
        return math.sqrt(num/(n-1))
    
