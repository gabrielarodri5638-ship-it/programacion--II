package ejerciciosdeprogramacion;
import java.util.Scanner;
public class ecuacioncuadratica {
	private double a ;
	private double b ;
	private double c ;
	public ecuacioncuadratica (double a,double b, double c) {
		this.a=a;
		this.b=b;
		this.c=c;
	}
	public double getdiscriminante() {
		double res=(Math.pow(this.b, 2))-4*this.a*this.c;
		return res;}
	public double getRAIZ1() {
		double num;
		num=-this.b+Math.sqrt((Math.pow(this.b, 2))-4*this.a*this.c);
		return num/2*this.a;
		
	}
	public double getRAIZ2() {
		double num;
		num=-this.b-Math.sqrt((Math.pow(this.b, 2))-4*this.a*this.c);
		return num/2*this.a;
		
	}
	public static void main(String[] args) {
		Scanner en =new Scanner(System.in);
		System.out.println("ingrese a,b,c: ");
		double a =en.nextDouble();
		double b =en.nextDouble();
		double c =en.nextDouble();
		ecuacioncuadratica eq = new ecuacioncuadratica(a, b, c);
        double disc = eq.getdiscriminante();
        if (disc > 0) {
            System.out.println("La ecuación tiene dos raíces " + eq.getRAIZ1() + " y " + eq.getRAIZ2());
        } 
        else if (disc == 0) {
            System.out.println("La ecuación tiene una raíz " + eq.getRAIZ1());
        } 
        else {
            System.out.println("La ecuación no tiene raíces reales");
        }

	}

}
